{
  "name": "club-performance-and-formation-optimizer",
  "private": true,
  "version": "0.1.0",
  "description": "AI-based football club player performance analysis and weekly formation optimization system",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check:structure": "node -e \"console.log('Project structure ready')\"",
    "dev:web": "npm run dev --workspace @club/web",
    "dev:api": "npm run dev --workspace @club/api",
    "dev:docker": "docker compose up --build",
    "dev:docker:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  }
}
